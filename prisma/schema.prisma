generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String              @unique
  passwordHash      String
  role              String              @default("user")
  currentMonth      Int                 @default(1)
  level             String              @default("iniciante")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  xpLog             XpLog[]
  badges            UserBadge[]
  streak            UserStreak?
  checklist         UserChecklist[]
  timerSessions     UserTimerSession[]
  monthProgress     UserMonthProgress[]
  quizAttempts      QuizAttempt[]
  flashcardProgress     FlashcardProgress[]
  collocationProgress   UserCollocationProgress[]
  sentenceProgress      UserSentenceProgress[]
  refreshTokens         RefreshToken[]
  savedPhrases          UserSavedPhrase[]
  readingContents       ReadingContent[]
  readingProgress       UserReadingProgress[]
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model XpLog {
  id        Int      @id @default(autoincrement())
  userId    String
  amount    Int
  source    String
  detail    String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id          Int         @id @default(autoincrement())
  slug        String      @unique
  name        String
  description String
  icon        String
  color       String      @default("#a078c0")
  xpReward    Int         @default(0)
  condition   String
  users       UserBadge[]
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   String
  badgeId  Int
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserStreak {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  current      Int      @default(0)
  longest      Int      @default(0)
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserChecklist {
  id     Int    @id @default(autoincrement())
  userId String
  date   String
  tasks  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model UserTimerSession {
  id          Int      @id @default(autoincrement())
  userId      String
  duration    Int
  completedAt DateTime @default(now())
  xpEarned    Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt])
}

model UserMonthProgress {
  id       Int  @id @default(autoincrement())
  userId   String
  month    Int
  progress Int  @default(0)
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
}

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  userId      String
  quizType    String
  totalQ      Int
  correct     Int
  xpEarned    Int      @default(0)
  month       Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt])
}

model FlashcardProgress {
  id             Int      @id @default(autoincrement())
  userId         String
  vocabularyId   Int
  ease           Float    @default(2.5)
  interval       Int      @default(1)
  repetitions    Int      @default(0)
  nextReviewAt   DateTime @default(now())
  lastReviewedAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId, nextReviewAt])
}

model Vocabulary {
  id         Int    @id @default(autoincrement())
  word       String
  type       String
  definition String
  example    String @default("")
  month      Int
  level      String @default("basico")
  category   String @default("geral")

  @@unique([word, month])
  @@index([month])
  @@index([level])
  @@index([category])
}

model PhrasalVerb {
  id      Int    @id @default(autoincrement())
  phrasal String
  meaning String
  example String
  month   Int

  @@unique([phrasal, month])
  @@index([month])
}

model Song {
  id              Int         @id @default(autoincrement())
  slug            String      @unique
  title           String
  artist          String
  youtubeId       String
  audioUrl        String      @default("")
  audioDurationMs Int         @default(0)
  lyricsOffsetMs  Int         @default(0)
  level           String
  themes          String[]
  learningNotes   String      @default("")
  month           Int         @default(1)
  keyPhrases      KeyPhrase[]
  vocabHighlights SongVocab[]
  lyricLines      SongLyricLine[]
  wordTimestamps  SongWordTimestamp[]
  savedPhrases    UserSavedPhrase[]

  @@index([month])
  @@index([level])
}

model SongLyricLine {
  id          Int    @id @default(autoincrement())
  songId      Int
  lineIndex   Int
  startMs     Int
  endMs       Int
  text        String
  translation String @default("")
  song        Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, lineIndex])
  @@index([songId])
  @@index([songId, startMs])
}

model SongWordTimestamp {
  id        Int    @id @default(autoincrement())
  songId    Int
  lineIndex Int
  wordIndex Int
  word      String
  startMs   Int
  endMs     Int
  song      Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([songId, lineIndex])
  @@unique([songId, lineIndex, wordIndex])
}

model TranslationCache {
  id           Int      @id @default(autoincrement())
  phrase       String
  contextHash  String
  context      String
  translation  String
  explanation  String   @default("")
  partOfSpeech String   @default("")
  createdAt    DateTime @default(now())
  hitCount     Int      @default(1)

  @@unique([phrase, contextHash])
  @@index([phrase])
  @@index([contextHash])
  @@index([hitCount(sort: Desc)])
}

model UserSavedPhrase {
  id          Int      @id @default(autoincrement())
  userId      String
  songId      Int?
  phrase      String
  translation String
  context     String
  sourceType  String   @default("lyric_click")
  status      String   @default("saved")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song        Song?    @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, songId])
}

model KeyPhrase {
  id     Int    @id @default(autoincrement())
  en     String
  pt     String
  songId Int
  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
}

model SongVocab {
  id      Int    @id @default(autoincrement())
  word    String
  meaning String
  songId  Int
  song    Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
}

model ReadingContent {
  id              Int               @id @default(autoincrement())
  title           String
  slug            String            @unique
  textHash        String            @unique
  fullText        String
  cefrLevel       String
  wordCount       Int               @default(0)
  estimatedTimeMs Int               @default(0)
  audioUrl        String            @default("")
  audioDurationMs Int               @default(0)
  ttsProvider     String            @default("azure")
  ttsVoice        String            @default("en-US-JennyNeural")
  sourceType      String            @default("curated")
  userId          String?
  month           Int               @default(1)
  category        String            @default("general")
  isPublic        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  sentences       ReadingSentence[]
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cefrLevel])
  @@index([month])
  @@index([userId])
  @@index([sourceType])
  @@index([category])
}

model ReadingSentence {
  id             Int                    @id @default(autoincrement())
  contentId      Int
  sentenceIndex  Int
  text           String
  translation    String                 @default("")
  startMs        Int
  endMs          Int
  content        ReadingContent         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  wordTimestamps ReadingWordTimestamp[]

  @@unique([contentId, sentenceIndex])
  @@index([contentId])
}

model ReadingWordTimestamp {
  id         Int             @id @default(autoincrement())
  sentenceId Int
  wordIndex  Int
  word       String
  startMs    Int
  endMs      Int
  sentence   ReadingSentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@index([sentenceId])
  @@unique([sentenceId, wordIndex])
}

model UserReadingProgress {
  id           Int       @id @default(autoincrement())
  userId       String
  contentId    Int
  lastSentence Int       @default(0)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  timeSpentMs  Int       @default(0)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([userId, completed])
}

model Video {
  id          Int    @id @default(autoincrement())
  title       String
  youtubeId   String @unique
  channel     String
  duration    String @default("")
  description String @default("")
  month       Int
  category    String
  level       String

  @@index([month])
  @@index([category])
  @@index([level])
}

model GrammarTip {
  id          Int      @id @default(autoincrement())
  title       String
  explanation String
  examples    String[]
  month       Int
  category    String   @default("geral")

  @@unique([title, month])
  @@index([month])
}

model Podcast {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  url         String
  level       String
  month       Int
  category    String @default("geral")

  @@unique([name, month])
  @@index([month])
}

model Expression {
  id         Int    @id @default(autoincrement())
  expression String
  meaning    String
  example    String
  month      Int
  category   String @default("idiom")

  @@unique([expression, month])
  @@index([month])
  @@index([category])
}

// ==================== OXFORD 3000/5000 REFERENCE ====================
model OxfordWord {
  id              Int       @id @default(autoincrement())
  word            String
  pos             String
  cefrLevel       String
  isOxford3000    Boolean   @default(false)
  frequencyRank   Int?
  definitionUrl   String    @default("")
  audioUrl        String    @default("")
  exampleSentence String    @default("")
  month           Int

  @@unique([word, pos])
  @@index([cefrLevel])
  @@index([month])
  @@index([frequencyRank])
  @@index([pos])
}

// ==================== COLLOCATIONS & PHRASES ====================
model Collocation {
  id              Int       @id @default(autoincrement())
  phrase          String
  baseWord        String
  collocate       String
  type            String
  meaning         String    @default("")
  example         String    @default("")
  cefrLevel       String
  month           Int
  audioUrl        String    @default("")

  exercises       CollocationExercise[]

  @@unique([phrase, type])
  @@index([cefrLevel])
  @@index([month])
  @@index([baseWord])
  @@index([type])
}

model CollocationExercise {
  id              Int       @id @default(autoincrement())
  collocationId   Int
  promptType      String
  prompt          String
  correctAnswer   String
  distractors     String[]
  cefrLevel       String
  month           Int

  collocation     Collocation @relation(fields: [collocationId], references: [id], onDelete: Cascade)

  @@index([collocationId])
  @@index([cefrLevel])
  @@index([month])
  @@index([promptType])
}

// ==================== SENTENCE COMPLETION ====================
model SentenceExercise {
  id              Int       @id @default(autoincrement())
  sentence        String
  correctAnswer   String
  distractors     String[]
  grammarFocus    String    @default("geral")
  cefrLevel       String
  month           Int
  explanation     String    @default("")

  @@index([cefrLevel])
  @@index([month])
  @@index([grammarFocus])
}

// ==================== USER PROGRESS (NEW EXERCISES) ====================
model UserCollocationProgress {
  id              Int       @id @default(autoincrement())
  userId          String
  collocationId   Int
  correct         Int       @default(0)
  attempts        Int       @default(0)
  mastered        Boolean   @default(false)
  lastAttemptAt   DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collocationId])
  @@index([userId])
  @@index([userId, mastered])
}

model UserSentenceProgress {
  id              Int       @id @default(autoincrement())
  userId          String
  exerciseId      Int
  correct         Int       @default(0)
  attempts        Int       @default(0)
  mastered        Boolean   @default(false)
  lastAttemptAt   DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([userId, mastered])
}
